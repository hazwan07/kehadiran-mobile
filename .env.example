# Environment Variables — Kehadiran Pekerja
# Copy file ini ke .env dan isi dengan nilai sebenar

# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.kehadiran.example.com

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxx

# Security — JANGAN commit ke git
# HMAC_SECRET disimpan di backend sahaja
# Device secrets disimpan di Firestore sahaja
